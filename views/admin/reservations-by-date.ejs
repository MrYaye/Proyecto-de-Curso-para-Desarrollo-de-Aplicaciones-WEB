<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reservas por Fecha</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container">
    <h1>Reservas por Fecha</h1>

    <a href="/admin/dashboard" class="btn btn-secondary">Volver al Dashboard</a>

    <div class="form-group">
      <label for="fecha">Seleccionar Fecha:</label>
      <input type="date" id="fecha" name="fecha" value="<%= fecha %>">
      <button type="submit" class="btn btn-primary" onclick="filterByDate()">Filtrar</button>
    </div>

    <h2>Reservas del <%= fecha %></h2>

    <% if (reservations.length > 0) { %>
      <table class="table">
        <thead>
          <tr>
            <th>Cliente</th>
            <th>Email</th>
            <th>Hora</th>
            <th>Mesa</th>
            <th>Personas</th>
            <th>Estado</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% reservations.forEach(reservation => { %>
            <tr>
              <td><%= reservation.nombre %></td>
              <td><%= reservation.email %></td>
              <td><%= reservation.hora_reserva %></td>
              <td><%= reservation.numero_mesa %></td>
              <td><%= reservation.numero_personas %></td>
              <td><span class="status-<%= reservation.estado %>"><%= reservation.estado %></span></td>
              <td>
                <% if (reservation.estado === 'pendiente') { %>
                  <a href="/admin/reservations/confirm/<%= reservation.id %>" class="btn btn-small btn-success">Confirmar</a>
                <% } %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } else { %>
      <p>No hay reservas para esta fecha</p>
    <% } %>
  </div>

  <script>
    function filterByDate() {
      const fecha = document.getElementById('fecha').value;
      if (fecha) {
        window.location.href = `/admin/reservations/by-date?fecha=${fecha}`;
      }
    }
  </script>

  <footer>
    <p>&copy; 2024 Sistema de Reservas - Todos los derechos reservados</p>
  </footer>
</body>
</html>
