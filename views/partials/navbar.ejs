<nav class="navbar">
  <div class="container navbar-container">
    <div class="nav-left">
      <% if (user && user.rol === 'admin') { %>
        <a href="/admin/dashboard" class="navbar-brand">🍽️ Restaurant Reservations</a>
      <% } else { %>
        <a href="/" class="navbar-brand">🍽️ Restaurant Reservations</a>
      <% } %>
    </div>

    <div class="nav-center">
    <% if (user) { %>
      <span class="user-greeting">Hola, <%= user.nombre %></span>
      <% if (user.rol === 'admin') { %>
        <a href="/admin/dashboard">Panel Admin</a>
      <% } else { %>
        <a href="/reservations/new">Nueva Reserva</a>
        <a href="/reservations/my-reservations">Mis Reservas</a>
      <% } %>
      <a href="/profile">Mi Perfil</a>
    <% } else { %>
      <a href="/login">Iniciar Sesión</a>
      <a href="/register">Registrarse</a>
    <% } %>
  </div>

  <% if (user) { %>
    <a href="/logout" class="logout-btn">Cerrar Sesión</a>
  <% } %>
  </div>
</nav>

<!-- Toast container (notificaciones) -->
<div id="toastContainer" class="toast-container" aria-live="polite" aria-atomic="true"></div>
<script src="/js/app.js"></script>

