<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mi Perfil</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container">
    <div class="form-container">
      <h1>Mi Perfil</h1>

      <% if (typeof messageProfile !== 'undefined' && messageProfile) { %>
        <script>
          document.addEventListener('DOMContentLoaded', function () {
            if (typeof showSuccess === 'function') showSuccess(<%- JSON.stringify(messageProfile) %>);
          });
        </script>
      <% } %>
      <% if (typeof messagePassword !== 'undefined' && messagePassword) { %>
        <script>
          document.addEventListener('DOMContentLoaded', function () {
            if (typeof showSuccess === 'function') showSuccess(<%- JSON.stringify(messagePassword) %>);
          });
        </script>
      <% } %>
      <% if (typeof errorProfile !== 'undefined' && errorProfile) { %>
        <script>
          (function () {
            const message = <%- JSON.stringify(errorProfile) %>;
            const display = () => { if (typeof showError === 'function') showError(message); };
            if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', display);
            else display();
          })();
        </script>
      <% } %>
      <% if (typeof errorPassword !== 'undefined' && errorPassword) { %>
        <script>
          (function () {
            const message = <%- JSON.stringify(errorPassword) %>;
            const display = () => { if (typeof showError === 'function') showError(message); };
            if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', display);
            else display();
          })();
        </script>
      <% } %>
      <% if (typeof error !== 'undefined' && error) { %>
        <script>
          (function () {
            const message = <%- JSON.stringify(error) %>;
            const display = () => { if (typeof showError === 'function') showError(message); };
            if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', display);
            else display();
          })();
        </script>
      <% } %>

      <form method="POST" action="/profile" class="auth-form" id="profileForm">
        <div class="form-group">
          <label for="nombre">Nombre Completo:</label>
          <input type="text" id="nombre" name="nombre" value="<%= user ? user.nombre : '' %>" required>
        </div>

        <div class="form-group">
          <label for="email">Email:</label>
          <input type="email" id="email" name="email" value="<%= user ? user.email : '' %>" required>
        </div>

        <div class="form-group">
          <label for="telefono">Teléfono:</label>
          <input type="tel" id="telefono" name="telefono" value="<%= user ? user.telefono : '' %>">
        </div>

        <div class="profile-buttons">
          <button type="submit" class="btn btn-primary">Guardar Cambios</button>
        </div>
      </form>
      
        <hr style="margin: 2rem 0; border: none; border-top: 1px solid #eee;">

        <div class="form-container">
          <h2>Cambiar contraseña</h2>
          <form method="POST" action="/profile" class="auth-form" id="passwordForm">
            <div class="form-group">
              <label for="currentPassword">Contraseña actual:</label>
              <input type="password" id="currentPassword" name="currentPassword" autocomplete="current-password">
            </div>

            <div class="form-group">
              <label for="newPassword">Nueva contraseña:</label>
              <input type="password" id="newPassword" name="newPassword" autocomplete="new-password">
            </div>

            <div class="form-group">
              <label for="confirmNewPassword">Confirmar nueva contraseña:</label>
              <input type="password" id="confirmNewPassword" name="confirmNewPassword" autocomplete="new-password">
            </div>

            <div class="profile-buttons">
              <button type="submit" class="btn btn-primary">Actualizar contraseña</button>
            </div>
          </form>
        </div>
    </div>
  </div>

  <script>
    const passwordForm = document.getElementById('passwordForm');
    const currentPassword = document.getElementById('currentPassword');
    const newPassword = document.getElementById('newPassword');
    const confirmNewPassword = document.getElementById('confirmNewPassword');

    function showPasswordError(message) {
      if (!message) return;
      if (typeof showError === 'function') showError(message);
      else alert(message);
    }

    passwordForm.addEventListener('submit', (event) => {
      const current = currentPassword.value.trim();
      const next = newPassword.value.trim();
      const confirm = confirmNewPassword.value.trim();

      if (!current && !next && !confirm) {
        return;
      }

      if (!current || !next || !confirm) {
        event.preventDefault();
        showPasswordError('Completa los tres campos para cambiar la contraseña.');
        return;
      }

      if (next.length < 8) {
        event.preventDefault();
        showPasswordError('La nueva contraseña debe tener al menos 8 caracteres.');
        return;
      }

      if (next !== confirm) {
        event.preventDefault();
        showPasswordError('Las nuevas contraseñas no coinciden.');
        return;
      }

      showPasswordError('');
    });
  </script>

  <footer>
    <p>&copy; 2026 Sistema de Reservas - Todos los derechos reservados</p>
  </footer>
</body>
</html>
