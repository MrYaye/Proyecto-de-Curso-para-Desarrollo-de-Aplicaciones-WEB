<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Editar Reserva</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container">
    <div class="form-container">
      <h1>Editar Reserva</h1>

      <% if (message) { %>
        <script>
          document.addEventListener('DOMContentLoaded', function () {
            if (typeof showSuccess === 'function') showSuccess(<%- JSON.stringify(message) %>);
          });
        </script>
      <% } %>
      <% if (error) { %>
        <script>
          (function () {
            const message = <%- JSON.stringify(error) %>;
            const display = () => { if (typeof showError === 'function') showError(message); };
            if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', display);
            else display();
          })();
        </script>
      <% } %>

      <form method="POST" action="/reservations/edit/<%= reservation.id %>" class="reservation-form" id="reservationForm">
        <div class="form-group">
          <label for="fecha">Fecha de Reserva:</label>
          <input type="date" id="fecha" name="fecha" value="<%= reservation.fecha_reserva.toISOString().split('T')[0] %>" required>
          <span class="form-note">Selecciona la fecha con el calendario.</span>
        </div>

        <div class="form-group">
          <label for="hora">Hora de Reserva:</label>
          <input type="time" id="hora" name="hora" value="<%= reservation.hora_reserva %>" required>
          <span class="form-note">Elige la hora y luego selecciona la mesa disponible.</span>
        </div>

        <div class="form-group">
          <label for="personas">Número de Personas:</label>
          <input type="number" id="personas" name="numPersonas" min="1" max="10" value="<%= reservation.numero_personas %>" required>
        </div>

        <div class="form-group" id="tablesContainer" style="display: none;">
          <label for="mesa">Seleccionar Mesa:</label>
          <select id="mesa" name="mesaId" required>
            <option value="">Cargando mesas disponibles...</option>
          </select>
        </div>

        <div class="form-group">
          <label for="observaciones">Observaciones (Opcional):</label>
          <textarea id="observaciones" name="observaciones" rows="4" placeholder="Preferencias especiales, alergias, etc."><%= reservation.observaciones || '' %></textarea>
        </div>

        <button type="submit" class="btn btn-primary">Guardar Cambios</button>
        <a href="/reservations/my-reservations" class="btn btn-secondary">Volver a Mis Reservas</a>
      </form>
    </div>
  </div>

  <script>
    const fechaInput = document.getElementById('fecha');
    const horaInput = document.getElementById('hora');
    const personasInput = document.getElementById('personas');
    const mesaSelect = document.getElementById('mesa');
    const tablesContainer = document.getElementById('tablesContainer');
    const reservationForm = document.getElementById('reservationForm');
    const reservaId = '<%= reservation.id %>';
    const currentMesaId = '<%= reservation.mesa_id %>';

    const today = new Date().toISOString().split('T')[0];
    fechaInput.setAttribute('min', today);

    async function loadAvailableTables() {
      if (!fechaInput.value || !horaInput.value || !personasInput.value) {
        tablesContainer.style.display = 'none';
        return;
      }

      try {
        const response = await fetch(`/reservations/available?fecha=${fechaInput.value}&hora=${horaInput.value}&personas=${personasInput.value}&reservaId=${reservaId}`);
        const tables = await response.json();

        mesaSelect.innerHTML = '';
        if (tables.length > 0) {
          tables.forEach(table => {
            const option = document.createElement('option');
            option.value = table.id;
            option.textContent = `Mesa ${table.numero_mesa} (Capacidad: ${table.capacidad})`;
            if (String(table.id) === currentMesaId) {
              option.selected = true;
            }
            mesaSelect.appendChild(option);
          });
          if (!mesaSelect.querySelector('option[selected]')) {
            const option = document.createElement('option');
            option.value = currentMesaId;
            option.textContent = `Mesa actual ${currentMesaId}`;
            option.selected = true;
            mesaSelect.prepend(option);
          }
          tablesContainer.style.display = 'block';
        } else {
          mesaSelect.innerHTML = '<option value="">No hay mesas disponibles</option>';
          tablesContainer.style.display = 'block';
        }
      } catch (error) {
        console.error('Error:', error);
        if (typeof showError === 'function') showError('Error al cargar las mesas disponibles');
        else alert('Error al cargar las mesas disponibles');
      }
    }

    function validateReservationForm(event) {
      if (!fechaInput.value || !horaInput.value || !personasInput.value) {
        return;
      }

      if (tablesContainer.style.display === 'block' && !mesaSelect.value) {
        event.preventDefault();
        if (typeof showError === 'function') showError('Selecciona una mesa antes de guardar los cambios.');
        else alert('Selecciona una mesa antes de guardar los cambios.');
        return;
      }
      // Form will submit normally
    }

    fechaInput.addEventListener('change', loadAvailableTables);
    horaInput.addEventListener('change', loadAvailableTables);
    personasInput.addEventListener('change', loadAvailableTables);
    reservationForm.addEventListener('submit', validateReservationForm);

    window.addEventListener('load', loadAvailableTables);
  </script>

  <footer>
    <p>&copy; 2024 Sistema de Reservas - Todos los derechos reservados</p>
  </footer>
</body>
</html>
