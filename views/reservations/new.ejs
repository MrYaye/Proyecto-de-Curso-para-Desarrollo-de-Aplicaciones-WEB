<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nueva Reserva</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container">
    <div class="form-container">
      <h1>Hacer una Reserva</h1>

      <% if (error) { %>
        <script>
          (function () {
            const message = <%- JSON.stringify(error) %>;
            const display = () => { if (typeof showError === 'function') showError(message); };
            if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', display);
            else display();
          })();
        </script>
      <% } %>

      <form method="POST" action="/reservations/create" class="reservation-form" id="reservationForm">
        <div class="form-group">
          <label for="fecha">Fecha de Reserva:</label>
          <input type="date" id="fecha" name="fecha" required>
          <span class="form-note">Selecciona la fecha con el calendario.</span>
        </div>

        <div class="form-group">
          <label for="hora">Hora de Reserva:</label>
          <input type="time" id="hora" name="hora" required>
          <span class="form-note">Elige la hora y luego selecciona la mesa disponible.</span>
        </div>

        <div class="form-group">
          <label for="personas">Número de Personas:</label>
          <input type="number" id="personas" name="numPersonas" min="1" max="10" required>
        </div>

        <div class="form-group" id="tablesContainer" style="display: none;">
          <label for="mesa">Seleccionar Mesa:</label>
          <select id="mesa" name="mesaId" required>
            <option value="">Cargando mesas disponibles...</option>
          </select>
        </div>

        <div class="form-group">
          <label for="observaciones">Observaciones (Opcional):</label>
          <textarea id="observaciones" name="observaciones" rows="4" placeholder="Preferencias especiales, alergias, etc."></textarea>
        </div>

        <div class="reserva-buttons">
          <button type="submit" class="btn btn-primary">Confirmar Reserva</button>
          <a href="/reservations/my-reservations" class="btn btn-secondary">Ver Mis Reservas</a>
        </div>
      </form>
    </div>
  </div>

  <script>
    const reservationForm = document.getElementById('reservationForm');
    const fechaInput = document.getElementById('fecha');
    const horaInput = document.getElementById('hora');
    const personasInput = document.getElementById('personas');
    const mesaSelect = document.getElementById('mesa');
    const tablesContainer = document.getElementById('tablesContainer');

    const today = new Date().toISOString().split('T')[0];
    fechaInput.setAttribute('min', today);

    async function loadAvailableTables() {
      if (!fechaInput.value || !horaInput.value || !personasInput.value) {
        tablesContainer.style.display = 'none';
        return;
      }

      try {
        const response = await fetch(`/reservations/available?fecha=${fechaInput.value}&hora=${horaInput.value}&personas=${personasInput.value}`);
        const tables = await response.json();

        mesaSelect.innerHTML = '';
        if (tables.length > 0) {
          tables.forEach(table => {
            const option = document.createElement('option');
            option.value = table.id;
            option.textContent = `Mesa ${table.numero_mesa} (Capacidad: ${table.capacidad})`;
            mesaSelect.appendChild(option);
          });
          tablesContainer.style.display = 'block';
        } else {
          mesaSelect.innerHTML = '<option value="">No hay mesas disponibles</option>';
          tablesContainer.style.display = 'block';
        }
      } catch (error) {
        console.error('Error:', error);
        if (typeof showError === 'function') showError('Error al cargar las mesas disponibles');
        else alert('Error al cargar las mesas disponibles');
      }
    }

    function validateReservationForm(event) {
      if (!fechaInput.value || !horaInput.value || !personasInput.value) {
        return;
      }

      if (tablesContainer.style.display === 'block' && !mesaSelect.value) {
        event.preventDefault();
        if (typeof showError === 'function') showError('Selecciona una mesa antes de confirmar la reserva.');
        else alert('Selecciona una mesa antes de confirmar la reserva.');
        return;
      }
      // Si llegó hasta aquí, el formulario se enviará
    }

    fechaInput.addEventListener('change', loadAvailableTables);
    horaInput.addEventListener('change', loadAvailableTables);
    personasInput.addEventListener('change', loadAvailableTables);
    reservationForm.addEventListener('submit', validateReservationForm);
  </script>

  <footer>
    <p>&copy; 2024 Sistema de Reservas - Todos los derechos reservados</p>
  </footer>
</body>
</html>
